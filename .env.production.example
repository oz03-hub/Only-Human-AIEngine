# Production Environment Configuration for GCP Cloud Run

# ============================================================================
# DATABASE - Cloud SQL PostgreSQL
# ============================================================================
# Format: postgresql+asyncpg://USER:PASSWORD@/DATABASE?host=/cloudsql/CONNECTION_NAME
# Cloud SQL Proxy uses Unix socket at /cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
DATABASE_URL=postgresql+asyncpg://aiengine_user:CHANGE_ME@/aiengine?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# ============================================================================
# OPENAI API
# ============================================================================
# Store in GCP Secret Manager and reference in cloudrun-service.yaml
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# API SECURITY
# ============================================================================
# Store in GCP Secret Manager and reference in cloudrun-service.yaml
# Generate with: openssl rand -base64 32
API_KEY=CHANGE_ME_GENERATE_SECURE_KEY

# ============================================================================
# Only Human URL
# ============================================================================
APPLICATION_WEBHOOK_URL=testingonlyhuman.com

# ============================================================================
# FACILITATION PIPELINE
# ============================================================================
MIN_MESSAGES=5
LIMIT_MESSAGES=10

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
ENV=production
LOG_LEVEL=INFO
MODEL_PATH=models/rf_classifier.pkl
LLM_MODEL=gpt-4o-mini

# ============================================================================
# CLOUD RUN CONFIGURATION
# ============================================================================
# Set automatically by Cloud Run, but can override for local testing
PORT=8000
